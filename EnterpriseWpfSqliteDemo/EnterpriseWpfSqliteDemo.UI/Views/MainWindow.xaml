<Window x:Class="EnterpriseWpfSqliteDemo.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EnterpriseWpfSqliteDemo - MVVM + EF Core" Height="450" Width="820">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="470"
                     Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="輸入待辦事項標題" />
            <Button Content="Add" Width="90" Margin="8,0,0,0"
                    Command="{Binding AddCommand}" />
            <Button Content="Refresh" Width="90" Margin="8,0,0,0"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Todos}"
                  SelectedItem="{Binding SelectedTodo}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="60" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsDone, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                <DataGridTextColumn Header="CreatedAt(UTC)" Binding="{Binding CreatedAtUtc}" IsReadOnly="True" Width="190" />

                <DataGridTemplateColumn Header="Actions" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Save" Width="70" Margin="0,0,8,0"
                                        Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Del" Width="70"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Margin="0,10,0,0" Text="{Binding Status}" Opacity="0.85"/>
    </Grid>
</Window>
